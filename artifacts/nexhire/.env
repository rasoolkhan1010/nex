# --- Google OAuth (for Sign In with Google) ---
# Get from: https://console.cloud.google.com/
# 1. Create project → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized origins: your Replit domain
VITE_GOOGLE_CLIENT_ID=206352440081-al8rekq3tbhkmackc9p6h7k31vuo13ca.apps.googleusercontent.com

# --- EmailJS (for notifications & newsletter) ---
# Get from: https://emailjs.com → free account
# 1. Add Email Service (connect Gmail: rasoolkhan990880@gmail.com)
# 2. Create Email Templates (see below)
# 3. Get Public Key from Account → API Keys
VITE_EMAILJS_SERVICE_ID=service_nexhire
VITE_EMAILJS_TEMPLATE_APPLY=template_apply
VITE_EMAILJS_TEMPLATE_CONTACT=template_contact
VITE_EMAILJS_TEMPLATE_NEWSLETTER=template_newsletter
VITE_EMAILJS_TEMPLATE_REGISTER=template_register
VITE_EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY

# --- Google Sheets API ---
